# Python 缓存与编译产物
__pycache__/
*.py[cod]
*.pyo
*.pyd

# 虚拟环境
.venv/
venv/
env/

# 本地大模型配置（含 API Key，不提交）
config_llm.json

# 光影文卷封面上传（保留目录）
static/uploads/content_covers/*
!static/uploads/content_covers/.gitkeep

# 本地数据库文件
file_remarks.db
file_remarks.db-journal

# 本地数据库备份目录（勿提交）
backups/

# 日志与临时文件
*.log
*.tmp
*.swp
*.swo

# 操作系统文件
.DS_Store
Thumbs.db

# 编辑器 / IDE 配置
.vscode/
.idea/

# Cursor 本地工程与缓存
.cursor/

# Node / 前端（如将来引入）
node_modules/
dist/
build/

# 本地依赖展开目录（勿提交）
.deps/

